wave_0_per_frame1=t1 = time * 0.15;
wave_0_per_frame2=t2 = bass_att * 0.20 + 0.18;
wave_0_per_point1=th = sample * 18.8496;
wave_0_per_point2=ros = t2 * (0.6 + 0.4*sin(th*3 + t1) + 0.15*sin(th*7 - t1*1.3));
wave_0_per_point3=x = 0.5 + ros*cos(th + t1*0.3);
wave_0_per_point4=y = 0.5 + ros*sin(th + t1*0.3);
wave_0_per_point5=hue = t1*2 + sample*0.5;
wave_0_per_point6=r = 0.5 + 0.5*sin(hue);
wave_0_per_point7=g = 0.5 + 0.5*sin(hue + 2.094);
wave_0_per_point8=b = 0.5 + 0.5*sin(hue + 4.189);
wave_0_per_point9=a = 0.6 + 0.4*sin(th*2);
