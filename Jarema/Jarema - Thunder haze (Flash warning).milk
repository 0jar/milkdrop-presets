wavecode_1_a=0.600
wave_1_per_frame1=t5 = time * 0.07;
wave_1_per_frame2=t6 = treb_att * 0.25 + 0.08;
wave_1_per_frame3=t7 = mid_att * 0.20 + 0.07;
wave_1_per_point1=s = sample * 6.2832;
wave_1_per_point2=fr1 = 3.0 + t6*8;
wave_1_per_point3=fr2 = 4.0 + t7*6;
wave_1_per_point4=x = 0.5 + 0.30*sin(fr1*s + t5);
wave_1_per_point5=y = 0.5 + 0.30*sin(fr2*s + t5*1.3);
wave_1_per_point6=hue2 = t5*2 + sample*0.8;
wave_1_per_point7=r = 0.5 + 0.5*sin(hue2 + 4.189);
wave_1_per_point8=g = 0.5 + 0.5*sin(hue2 + 2.094);
wave_1_per_point9=b = 1.0;
wave_1_per_point10=a = 0.3 + treb_att * 0.7;
