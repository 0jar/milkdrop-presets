wave_2_per_frame1=t8 = bass_att * 0.15 + 0.06;
wave_2_per_frame2=t9 = time * 0.5;
wave_2_per_point1=th2 = sample * 6.2832;
wave_2_per_point2=pls = t8 * (1 + 0.3*sin(th2*8 + t9));
wave_2_per_point3=x = 0.5 + pls*cos(th2);
wave_2_per_point4=y = 0.5 + pls*sin(th2);
wave_2_per_point5=hue3 = t9 + sample*0.3;
wave_2_per_point6=r = 0.6 + 0.4*sin(hue3);
wave_2_per_point7=g = 0.2 + 0.3*sin(hue3 + 2.094);
wave_2_per_point8=b = 0.8 + 0.2*sin(hue3 + 4.189);
wave_2_per_point9=a = 0.35 + bass_att * 0.65;
