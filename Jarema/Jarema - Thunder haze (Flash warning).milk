per_frame_1=q1 = bass_att;
per_frame_2=q2 = treb_att;
per_frame_3=q3 = mid_att;
per_frame_4=q4 = time;
per_frame_5=decay = 0.93 - bass_att*0.02;
per_frame_6=zoom = 1.002 + bass_att*0.003;
per_frame_7=rot = 0.002 + mid_att*0.0005;
per_frame_8=warp = 0.25 + bass_att*0.4;
per_frame_9=wave_a = 0;
warp_1=`shader_body
warp_2=`{
warp_3=`    // fluid displacement
warp_4=`    float2 noise_uv = uv_orig * texsize.xy * texsize_noise_lq.zw * 0.5;
warp_5=`    float4 n1 = tex2D(sampler_noise_lq, noise_uv + rand_frame.xy * 0.12);
warp_6=`    float4 n2 = tex2D(sampler_noise_lq, noise_uv * 0.4 + rand_frame.zw * 0.08);
warp_7=`
warp_8=`    // bass displacement
warp_9=`    float bassamt = saturate(q1);
warp_10=`    float2 disp = (n1.xy - 0.5) * 0.008 * (1.0 + bassamt * 2.0);
warp_11=`    disp += (n2.xy - 0.5) * 0.004;
warp_12=`
warp_13=`    // sample previous frame
warp_14=`    ret.xyz = tex2D(sampler_main, uv + disp).xyz;
warp_15=`
warp_16=`    // blur blend
warp_17=`    ret.xyz = lerp(ret.xyz, GetBlur1(uv + disp).xyz, 0.05);
warp_18=`
warp_19=`    // treble grain
warp_20=`    float spark = (tex2D(sampler_noise_lq, noise_uv * 4.0 + rand_frame.yx).x - 0.5) * 2.0;
warp_21=`    ret.xyz += spark * saturate(q2 - 0.55) * 0.03;
warp_22=`    ret *= .93 - bass_att*.02;
warp_23=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    float3 col = tex2D(sampler_main, uv).xyz;
comp_4=`
comp_5=`    // bloom
comp_6=`    float3 b1 = GetBlur1(uv).xyz;
comp_7=`    col = col + b1 * 0.20;
comp_8=`
comp_9=`    // cool grade
comp_10=`    col.x *= 0.88;
comp_11=`    col.z = saturate(col.z * 1.08);
comp_12=`
comp_13=`    // soft tone curve
comp_14=`    col = col / (col + 0.3) * 1.3;
comp_15=`
comp_16=`    // vignette
comp_17=`    float2 vc = uv - 0.5;
comp_18=`    float vig = saturate(1.0 - dot(vc, vc) * 1.5);
comp_19=`    col *= vig;
comp_20=`
comp_21=`    // bass bloom
comp_22=`    float flash = saturate((q1 - 0.75) * 4.0) * 0.20;
comp_23=`    col += float3(flash * 0.2, flash * 0.6, flash * 1.0);
comp_24=`
comp_25=`    ret.xyz = col;
comp_26=`}
