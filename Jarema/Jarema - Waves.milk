wavecode_1_smoothing=0.50000
wavecode_1_r=0.200
wavecode_1_g=0.600
wavecode_1_b=1.000
wavecode_1_a=0.700
wave_1_init1=t2 = rand(100)*0.01;
wave_1_per_point1=ti = time*0.9;
wave_1_per_point2=sample = sample*0.99 + 0.005;
wave_1_per_point3=rad = 0.2 + 0.12*cos(ti*t2 + sample*3.14) + 0.06*((bass+mid+treb)*0.333);
wave_1_per_point4=ang = sample*6.28*2 - ti*0.3;
wave_1_per_point5=x = 0.5 + rad*cos(ang)*1.2;
wave_1_per_point6=y = 0.5 + rad*sin(ang);
wave_1_per_point7=r = 0.2 + 0.3*sin(ti*1.1);
wave_1_per_point8=g = 0.5 + 0.4*sin(ti*0.9);
wave_1_per_point9=b = 0.8 + 0.2*cos(ti*0.6);
wave_1_per_point10=a = 0.2 + 0.2*bass + 0.15*mid + 0.1*treb;
shapecode_0_enabled=1
shapecode_0_sides=100
