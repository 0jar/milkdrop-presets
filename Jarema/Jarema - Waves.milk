shape_0_per_frame1=rad = 2.0 + 0.4*((bass+mid+treb)*0.333) + 0.3*sin(time*0.3);
shape_0_per_frame2=tex_zoom = 0.5/rad;
shape_0_per_frame3=a = 0.10 + 0.08*bass_att + 0.04*mid_att + 0.04*treb_att;
shape_0_per_frame4=a2 = a;
