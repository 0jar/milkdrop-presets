wave_0_init1=t1 = rand(100)*0.01;
wave_0_per_point1=ti = time*1.2;
wave_0_per_point2=sample = sample*0.99 + 0.005;
wave_0_per_point3=rad = 0.15 + 0.18*sin(ti + sample*6.28*2) + 0.08*((bass+mid)*0.5);
wave_0_per_point4=ang = sample*6.28*3 + ti*0.4;
wave_0_per_point5=x = 0.5 + rad*cos(ang);
wave_0_per_point6=y = 0.5 + rad*sin(ang);
wave_0_per_point7=r = 0.1 + 0.4*sin(ti*0.8 + sample*6.28);
wave_0_per_point8=g = 0.3 + 0.5*sin(ti*0.8 + 2.094 + sample*6.28);
wave_0_per_point9=b = 0.7 + 0.3*sin(ti*0.8 + 4.189 + sample*6.28);
wave_0_per_point10=a = 1;
