per_frame_1=wave_r = 0.2 + 0.3*sin(time*0.713);
per_frame_2=wave_g = 0.3 + 0.4*sin(time*0.847);
per_frame_3=wave_b = 0.6 + 0.4*sin(time*0.967);
per_frame_4=q1 = bass;
per_frame_5=q2 = mid;
per_frame_6=q3 = treb;
per_frame_7=q4 = bass_att;
per_frame_8=q5 = time;
per_frame_9=decay = 0.97 + 0.015*(bass_att + mid_att + treb_att);
per_frame_10=zoom = 1.0 + 0.02*(bass - 0.8) + 0.015*(mid - 0.8) + 0.015*(treb - 0.8);
per_frame_11=rot = 0.006*(bass - 0.9) + 0.004*(mid - 0.9) + 0.004*(treb - 0.9);
per_frame_12=wave_x = 0.5 + 0.06*((bass+mid+treb)*0.333)*sin(time*0.4);
per_frame_13=wave_y = 0.5 + 0.06*((bass+mid+treb)*0.333)*cos(time*0.6);
per_pixel_1=zoom = zoom + 0.025*((bass+mid+treb)*0.333)*sin(rad*8 + time);
per_pixel_2=rot = rot + 0.015*((bass+mid+treb)*0.333)*sin(ang*3 - time*0.4);
warp_1=`shader_body
warp_2=`{
warp_3=`    float2 uv2 = uv;
warp_4=`    float t = time * 0.5;
warp_5=`    
warp_6=`    // fluid displacement
warp_7=`    float angle = sin(uv.y*10.0 + t)*cos(uv.x*8.0 - t*0.7)*6.283;
warp_8=`    float strength = 0.006 + 0.008 * ((bass_att+mid_att+treb_att)*0.333);
warp_9=`    float2 disp = float2(cos(angle), sin(angle)) * strength;
warp_10=`    
warp_11=`    // radial bulge
warp_12=`    float2 centered = uv - 0.5;
warp_13=`    float dist = length(centered);
warp_14=`    disp += centered * dist * 0.025 * ((bass+mid+treb)*0.333 - 0.7);
warp_15=`    
warp_16=`    uv2 += disp;
warp_17=`    
warp_18=`    float3 ret2 = tex2D(sampler_main, uv2).xyz;
warp_19=`    
warp_20=`    // subtle sharpen
warp_21=`    float3 blurry = GetBlur1(uv2).xyz;
warp_22=`    ret2 += (ret2 - blurry) * 0.15;
warp_23=`    
warp_24=`    // desaturate and longer decay
warp_25=`    float lum2 = dot(ret2, float3(0.3,0.5,0.2));
warp_26=`    ret2 = lerp(ret2, lum2.xxx, 0.08);
warp_27=`    ret2 *= 0.985 + 0.01 * ((bass_att+mid_att+treb_att)*0.333);
warp_28=`    
warp_29=`    ret.xyz = ret2;
warp_30=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    float2 uv2;
comp_4=`    float2 d = texsize.zw*2.0;
comp_5=`    float2 centered = uv - 0.5;
comp_6=`    float dist = length(centered)*1.414;
comp_7=`    
comp_8=`    // edge detect on blurred source
comp_9=`    uv2 = uv + float2(1,0)*d;
comp_10=`    float3 gxr = GetBlur1(uv2);
comp_11=`    uv2 = uv - float2(1,0)*d;
comp_12=`    float3 gxl = GetBlur1(uv2);
comp_13=`    uv2 = uv + float2(0,1)*d;
comp_14=`    float3 gyu = GetBlur1(uv2);
comp_15=`    uv2 = uv - float2(0,1)*d;
comp_16=`    float3 gyd = GetBlur1(uv2);
comp_17=`    
comp_18=`    float3 grad = abs(gxr-gxl) + abs(gyu-gyd);
comp_19=`    float edge = length(grad)*2.5;
comp_20=`    
comp_21=`    float3 base = GetPixel(uv);
comp_22=`    
comp_23=`    // cyan edge glow
comp_24=`    float3 neon = float3(0.0, 0.5, 1.0) * edge * 0.7;
comp_25=`    neon += float3(0.2, 0.8, 1.0) * edge * sin(time*0.7 + dist*5.0) * 0.7;
comp_26=`    
comp_27=`    // reactive pulse
comp_28=`    float audio = (bass + mid + treb) * 0.333;
comp_29=`    neon *= 1.0 + audio * 0.5;
comp_30=`    
comp_31=`    // shadows deep navy, highlights cyan-white
comp_32=`    float luma = lum(base);
comp_33=`    float3 dark = base * float3(0.05, 0.15, 0.45);
comp_34=`    float3 bright = base * float3(0.3, 0.7, 1.0);
comp_35=`    base = lerp(dark, bright, smoothstep(0.0, 0.5, luma));
comp_36=`    
comp_37=`    ret = base + neon*0.4;
comp_38=`    ret *= 0.9 + audio*0.08;
comp_39=`}

