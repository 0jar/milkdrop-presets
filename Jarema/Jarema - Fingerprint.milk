wave_0_init1=t1 = rand(100)*0.01;
wave_0_per_point1=ti = time*1.0;
wave_0_per_point2=sample = sample*0.99 + 0.005;
wave_0_per_point3=rad = 0.12 + 0.10*sin(ti + sample*6.28*2) + 0.06*((bass+mid)*0.5);
wave_0_per_point4=ang = sample*6.28*3 + ti*0.35;
wave_0_per_point5=x = 0.5 + rad*cos(ang);
wave_0_per_point6=y = 0.5 + rad*sin(ang);
wave_0_per_point7=r = 0.1 + 0.4*sin(ti*0.7 + sample*6.28);
wave_0_per_point8=g = 0.3 + 0.5*sin(ti*0.7 + 2.094 + sample*6.28);
wave_0_per_point9=b = 0.7 + 0.3*sin(ti*0.7 + 4.189 + sample*6.28);
wave_0_per_point10=a = 0.6 + 0.4*bass;
