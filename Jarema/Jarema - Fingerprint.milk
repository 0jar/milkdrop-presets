per_frame_1=wave_r = 0.1 + 0.3*sin(time*0.713);
per_frame_2=wave_g = 0.3 + 0.4*sin(time*0.847);
per_frame_3=wave_b = 0.6 + 0.4*sin(time*0.967);
per_frame_4=q1 = bass;
per_frame_5=q2 = mid;
per_frame_6=q3 = treb;
per_frame_7=q4 = bass_att;
per_frame_8=q5 = time;
per_frame_9=zoom = 1.0 + 0.012*(bass + mid*0.5 + treb*0.25 - 1.2);
per_frame_10=rot = 0.003*(bass + mid*0.5);
per_frame_11=wave_x = 0.5 + 0.05*sin(time*0.3);
per_frame_12=wave_y = 0.5 + 0.05*cos(time*0.5);
per_pixel_1=zoom = zoom + 0.02*((bass+mid+treb)*0.333)*sin(rad*8 + time);
per_pixel_2=rot = rot + 0.012*((bass+mid+treb)*0.333)*sin(ang*4 - time*0.35);
warp_1=`shader_body
warp_2=`{
warp_3=`    float2 uv2 = uv;
warp_4=`    float2 d = texsize.zw * 3.0;
warp_5=`    
warp_6=`    // smooth luminance gradient from blur
warp_7=`    float gradX = lum(GetBlur2(uv + float2(d.x,0))) - lum(GetBlur2(uv - float2(d.x,0)));
warp_8=`    float gradY = lum(GetBlur2(uv + float2(0,d.y))) - lum(GetBlur2(uv - float2(0,d.y)));
warp_9=`    
warp_10=`    // fluid follows its own brightness
warp_11=`    float strength = 0.007 + 0.003*((bass_att+mid_att+treb_att)*0.333);
warp_12=`    float2 disp = float2(gradX, gradY) * strength;
warp_13=`    
warp_14=`    // slow rotating drift
warp_15=`    float t = time * 0.35;
warp_16=`    float2 drift = float2(cos(t + uv.y*6.28), sin(t + uv.x*6.28)) * 0.0015;
warp_17=`    
warp_18=`    // radial breathing
warp_19=`    float2 centered = uv - 0.5;
warp_20=`    float dist = length(centered);
warp_21=`    disp += centered * dist * 0.012 * ((bass+mid+treb)*0.333 - 1.0);
warp_22=`    
warp_23=`    uv2 += disp + drift;
warp_24=`    
warp_25=`    // sample smeared previous frame
warp_26=`    float3 prev = tex2D(sampler_main, uv2).xyz;
warp_27=`    
warp_28=`    // gentle sharpen
warp_29=`    float3 blur = GetBlur1(uv2);
warp_30=`    prev += (prev - blur) * 0.08;
warp_31=`    
warp_32=`    // blue light on beats
warp_33=`    prev += float3(0.0, 0.002, 0.005) * (bass + mid);
warp_34=`    
warp_35=`    // self-darkening to balance high fDecay
warp_36=`    prev *= 0.995;
warp_37=`    
warp_38=`    ret.xyz = prev;
warp_39=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    float3 col = GetPixel(uv);
comp_4=`    
comp_5=`    // dark areas go navy, bright areas go cyan-white
comp_6=`    float l = lum(col);
comp_7=`    float3 darkTint = float3(0.2, 0.5, 1.2);
comp_8=`    float3 brightTint = float3(0.8, 1.0, 1.3);
comp_9=`    col = lerp(col * darkTint, col * brightTint, smoothstep(0.0, 0.5, l));
comp_10=`    
comp_11=`    // overall dimming
comp_12=`    col *= 0.85;
comp_13=`    
comp_14=`    // soft edge vignette
comp_15=`    float2 c = uv - 0.5;
comp_16=`    col *= 1.0 - length(c)*0.12;
comp_17=`    
comp_18=`    ret = col;
comp_19=`}

