per_frame_1=wave_r = 0.5 + 0.5*sin(time*0.713);
per_frame_2=wave_g = 0.5 + 0.5*sin(time*0.847);
per_frame_3=wave_b = 0.5 + 0.5*sin(time*0.967);
per_frame_4=q1 = bass;
per_frame_5=q2 = mid;
per_frame_6=q3 = treb;
per_frame_7=q4 = bass_att;
per_frame_8=q5 = time;
per_frame_9=decay = 0.97 + 0.02*bass_att;
per_frame_10=zoom = 1.0 + 0.01*(bass - 1.0);
per_frame_11=rot = rot + 0.01*(mid - 1.0);
per_frame_12=wave_x = 0.5 + 0.1*sin(time*0.5);
per_frame_13=wave_y = 0.5 + 0.1*cos(time*0.7);
per_pixel_1=zoom = zoom + 0.03*sin(rad*10 + time);
per_pixel_2=rot = rot + 0.02*sin(ang*5 - time*0.5);
warp_1=`shader_body
warp_2=`{
warp_3=`    float2 uv2 = uv;
warp_4=`    float3 prev = tex2D(sampler_main, uv2).xyz;
warp_5=`    
warp_6=`    float2 delta = texsize.zw*2.0;
warp_7=`    float3 blurry = GetBlur2(uv2).xyz;
warp_8=`    
warp_9=`    // fluid displacement
warp_10=`    float2 disp = (blurry.xy - 0.5) * 0.025 * (1.0 + q4);
warp_11=`    uv2 += disp;
warp_12=`    
warp_13=`    float3 ret2 = tex2D(sampler_main, uv2).xyz;
warp_14=`    
warp_15=`    // sharpen
warp_16=`    ret2 += (ret2 - blurry)*0.35;
warp_17=`    
warp_18=`    // desaturate
warp_19=`    float lum2 = dot(ret2, float3(0.3,0.5,0.2));
warp_20=`    ret2 = lerp(ret2, lum2.xxx, 0.15);
warp_21=`    
warp_22=`    // darken and add energy on treb
warp_23=`    ret2 *= 0.92 + 0.08*q3;
warp_24=`    
warp_25=`    ret.xyz = ret2;
warp_26=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    float2 uv2;
comp_4=`    float2 d = texsize.zw*1.5;
comp_5=`    
comp_6=`    // edge detection
comp_7=`    uv2 = uv + float2(1,0)*d;
comp_8=`    float3 gxr = GetPixel(uv2)*0.5 + GetBlur1(uv2)*0.3 + GetBlur2(uv2)*0.2;
comp_9=`    uv2 = uv - float2(1,0)*d;
comp_10=`    float3 gxl = GetPixel(uv2)*0.5 + GetBlur1(uv2)*0.3 + GetBlur2(uv2)*0.2;
comp_11=`    uv2 = uv + float2(0,1)*d;
comp_12=`    float3 gyu = GetPixel(uv2)*0.5 + GetBlur1(uv2)*0.3 + GetBlur2(uv2)*0.2;
comp_13=`    uv2 = uv - float2(0,1)*d;
comp_14=`    float3 gyd = GetPixel(uv2)*0.5 + GetBlur1(uv2)*0.3 + GetBlur2(uv2)*0.2;
comp_15=`    
comp_16=`    float3 grad = abs(gxr-gxl) + abs(gyu-gyd);
comp_17=`    float edge = length(grad)*3.0;
comp_18=`    
comp_19=`    float3 base = GetPixel(uv);
comp_20=`    
comp_21=`    // edge glow
comp_22=`    float3 neon = float3(0.2, 0.8, 1.0) * edge;
comp_23=`    neon += float3(1.0, 0.3, 0.5) * edge * sin(q5*0.7);
comp_24=`    
comp_25=`    // color grade
comp_26=`    float luma = lum(base);
comp_27=`    float3 dark = base * float3(0.4, 0.6, 1.0);
comp_28=`    float3 bright = base * float3(1.0, 0.9, 0.6);
comp_29=`    base = lerp(dark, bright, smoothstep(0.0, 0.6, luma));
comp_30=`    
comp_31=`    // add edges back in
comp_32=`    ret = base + neon*0.5;
comp_33=`    ret *= 1.1;
comp_34=`}

