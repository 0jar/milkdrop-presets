wave_0_per_point1=ti = time*1.5;
wave_0_per_point2=sample = sample*0.99 + 0.005;
wave_0_per_point3=rad = 0.2 + 0.15*sin(ti*t1 + sample*6.28);
wave_0_per_point4=ang = sample*6.28*3 + ti*0.3;
wave_0_per_point5=x = 0.5 + rad*cos(ang) + 0.05*sin(ti*2.7);
wave_0_per_point6=y = 0.5 + rad*sin(ang) + 0.05*cos(ti*1.9);
wave_0_per_point7=r = 0.5 + 0.5*sin(ti + sample*6.28);
wave_0_per_point8=g = 0.5 + 0.5*sin(ti + 2.094 + sample*6.28);
wave_0_per_point9=b = 0.5 + 0.5*sin(ti + 4.189 + sample*6.28);
