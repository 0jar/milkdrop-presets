wave_2_per_frame2=t8=q3*0.3+0.10;
wave_2_per_point1=s2=sample*6.2832;
wave_2_per_point2=x=0.5+0.27*sin(3*s2+t7);
wave_2_per_point3=y=0.5+0.27*sin(4*s2+t7*1.1);
