wave_0_per_frame1=t1=q1*0.3;
wave_0_per_point1=s=sample*6.2832;
wave_0_per_point2=xp=(sin(s)+2*sin(2*s))*0.13;
wave_0_per_point3=yp=(cos(s)-2*cos(2*s))*0.13;
wave_0_per_point4=zp=(-sin(3*s))*0.13;
wave_0_per_point5=ang=t1;
wave_0_per_point6=sang=sin(ang);cang=cos(ang);
wave_0_per_point7=xq=xp*cang-zp*sang;zq=xp*sang+zp*cang;
wave_0_per_point8=xp=xq;zp=zq;
wave_0_per_point9=ang=t1*0.7;
wave_0_per_point10=sang=sin(ang);cang=cos(ang);
wave_0_per_point11=yq=yp*cang-zp*sang;zq=yp*sang+zp*cang;
wave_0_per_point12=yp=yq;zp=zq;
wave_0_per_point13=zp=zp+1.8;
wave_0_per_point14=x=xp/zp+0.5;
wave_0_per_point15=y=yp/zp*1.333+0.5;
wave_0_per_point16=r=treb;
wave_0_per_point17=g=mid;
wave_0_per_point18=b=bass;
wave_0_per_point19=a=0.9;
