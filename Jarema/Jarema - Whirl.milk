wave_1_per_frame1=t5=q2*0.18+0.07;
wave_1_per_frame2=t6=q4*0.6;
wave_1_per_point1=th=sample*6.2832;
wave_1_per_point2=rv=t5*(1+0.35*sin(th*6+t6));
wave_1_per_point3=x=0.5+rv*cos(th);
wave_1_per_point4=y=0.5+rv*sin(th);
wave_1_per_point5=r=0.9+0.1*sin(t6);
wave_1_per_point6=g=0.1+0.2*sin(t6*1.3);
wave_1_per_point7=b=0.7+0.3*sin(t6*0.7);
wave_1_per_point8=a=0.4+0.6*bass;
