per_frame_1=decay=0.94;
per_frame_2=zoom=1.001+bass_att*0.002;
per_frame_3=warp=0;
per_frame_4=q1=time*0.35;
per_frame_5=q2=bass_att;
per_frame_6=q3=treb_att;
per_frame_7=q4=time;
per_frame_8=wave_a=0;
warp_1=`shader_body
warp_2=`{
warp_3=`    // swirl
warp_4=`    float2 d = uv - 0.5;
warp_5=`    float dist = length(d);
warp_6=`    float angle = q2 * 0.012 * max(0.0, 0.7 - dist);
warp_7=`    float c = cos(angle);
warp_8=`    float sa = sin(angle);
warp_9=`    float2 uvs;
warp_10=`    uvs.x = d.x*c - d.y*sa + 0.5;
warp_11=`    uvs.y = d.x*sa + d.y*c + 0.5;
warp_12=`    ret = tex2D(sampler_main, uvs).xyz;
warp_13=`    // noise grain on mid
warp_14=`    float2 nuv = uv_orig * texsize.xy * texsize_noise_lq.zw;
warp_15=`    float4 n = tex2D(sampler_noise_lq, nuv + rand_frame.xy);
warp_16=`    ret.xyz += (n.xyz - 0.5) * 0.006 * saturate(q3 - 0.4);
warp_17=`    ret *= .94;
warp_18=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    ret = tex2D(sampler_main, uv).xyz;
comp_4=`    // gamma lift
comp_5=`    ret = pow(saturate(ret), float3(0.85, 0.90, 0.82));
comp_6=`    // vignette
comp_7=`    float2 vc = uv - 0.5;
comp_8=`    ret *= saturate(1.15 - dot(vc, vc) * 1.8);
comp_9=`}
